# RetornoMX GPS Gateway - Variables de entorno Railway

# Secret compartido con RetornoMX (Vercel)
# Genera uno con: openssl rand -hex 32
GATEWAY_SECRET=genera_uno_con_openssl_rand_hex_32

# Llave de encriptación AES-256 (32 bytes = 64 chars hex)
# Genera uno con: openssl rand -hex 32
# MISMO valor debe estar en Supabase/RetornoMX para encriptar credenciales
ENCRYPTION_KEY=genera_uno_con_openssl_rand_hex_32

# Puerto (Railway lo asigna automáticamente)
PORT=3001
